{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/proxy.js", "use": "@vercel/node" },
    { "src": "api/debug.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/extract", "dest": "/api/index.js" },
    { "src": "/api/proxy",   "dest": "/api/proxy.js"  },
    { "src": "/api/debug",   "dest": "/api/debug.js"  },
    { "src": "/(.*)",        "dest": "/public/$1"     }
  ]
}
