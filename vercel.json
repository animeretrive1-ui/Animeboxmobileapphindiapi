{
  "version": 2,
  "functions": {
    "api/index.js": { "runtime": "nodejs18.x", "maxDuration": 30, "memory": 512 },
    "api/proxy.js":  { "runtime": "nodejs18.x", "maxDuration": 30, "memory": 512 },
    "api/debug.js":  { "runtime": "nodejs18.x", "maxDuration": 30, "memory": 256 }
  },
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/proxy.js", "use": "@vercel/node" },
    { "src": "api/debug.js", "use": "@vercel/node" },
    { "src": "public/**",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/extract", "dest": "/api/index.js" },
    { "src": "/api/proxy",   "dest": "/api/proxy.js"  },
    { "src": "/api/debug",   "dest": "/api/debug.js"  },
    { "src": "/(.*)",        "dest": "/public/$1"     }
  ]
}
